{
  "name": "propath",
  "version": "0.1.0",
  "private": true,
  "description": "ProPath monorepo — React frontend + Express API",
  "scripts": {
    "start": "npm start --prefix frontend",
    "start:frontend": "npm start --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "build": "npm run build --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "test": "npm test --prefix frontend",
    "test:smoke": "npm run test:smoke --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "install:backend": "npm install --prefix backend",
    "install:all": "npm install --prefix frontend && npm install --prefix backend"
  }
}
